#Can use a for loop for different alpha values - we only used 3 dif ones
#StatQuest has an example
#EN - when you want to extract as much predictive power and allow the function to search for you
#EN - when you want to extract as much predictive power and allow the function to search for you
mean((y - prd.fl[,1]) ^ 2)  ## against cvx$lambda.min
mean((y - prd.fl[,2]) ^ 2)  ## against cvx$lambda.1se
?predict.cv.glmnet #same as predict()
## predictions at the first two vectors of x!
predict(cvx, newx = x[1:2,], s = c(0.01, cvx$lambda.min, cvx$lambda.1se))
#1 is lambda.min and 2 is lambda.1se
# s = Value(s) of the penalty parameter lambda at which predictions are required. Default is the entire sequence used to create the model.
prd.fl <- predict(cvx, newx = x, s = c(cvx$lambda.min, cvx$lambda.1se))
dim(prd.fl)
head(prd.fl)
#1 is lambda.min and 2 is lambda.1se
# s = Value(s) of the penalty parameter lambda at which predictions are required. Default is the entire sequence used to create the model.
prd.fl <- predict(cvx, newx = x, s = c(cvx$lambda.min, cvx$lambda.1se))
dim(prd.fl)
head(prd.fl)
cvx$lambda
lambda <- sort(cvx$lambda) #smaller to higher - how it loooks on the x axis anyway
lambda
wh <- which(lambda >= cvx$lambda.min & lambda <= cvx$lambda.1se)
wh
sps.set <- lambda[wh]  ## and this is the set we want!
sps.set
prd.sps.set <- predict(cvx, newx = x, s = sps.set) #for all 21 models
## so we got the predictions, how many?
dim(prd.sps.set) #442 21
mse <- function (i,y) {
mean ( (y - i) ^ 2 )
}		## quite simple!
mean((y - prd.fl[,1])^2)  ## against cvx$lambda.min
mean((y - prd.fl[,2])^2)  ## against cvx$lambda.1se
apply(prd.fl , 2, mse, y)
mse.sps.set <- apply(prd.sps.set, 2, mse, y)
plot(sps.set, mse.sps.set)
plot(log(sps.set), mse.sps.set)	## better on the log-sale
## To see how much the difference really is!
plot(log(sps.set), mse.sps.set / min(mse.sps.set) * 100 - 100 )
csps.set <- coef(cvx, s = sps.set) #lambda values between mean and 1se
t(as.matrix(csps.set))[,-1]  ## intercept is always there!
cvxg <- glmnet(x, y, lambda = cvx$lambda)
?plot.glmnet
par(mfrow = c(1, 2))
plot(cvxg) ## coefs against the norm - identify the models corresponding
## to L1-nomr=0 and its largest values!
plot(cvxg, xvar = "lambda") ## coefs against the norm - again,
#L1 norm = sum of abs values of beta js --> the <=t section of the slides
#as L1 norm decreases - coefs become 0 as there is no wiggle room
#as we relax, increase L1 norm, coef increases
#regularization - trying to control coef during the estimation process
#important when there are large number of predictors
