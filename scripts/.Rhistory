##-----------------------------------------------------
##	Tuning Over a Grid of alpha-lambda Values
##-----------------------------------------------------
##---------------------------------------------------------------
# The tuning approach implemented via the caret package above is a general one and may not be applicable in all situations. For instance, it is important in glmnet's implementation of elasticnet to work with a grid of lambda values for a given 'fixed' value of alpha. However, caret calls glmnet by fixing 'both' lambda and alpha in each iteration over the tuneGrid matrix.
# We can handle this issue as follows by relying solely on glmnet functionality alone.
## First, it is a good idea to keep the folds fixed throughout the cross-validations. There are various ways to do it (you should explore this!); here we can extract the folds from a cv.glmnet:
## We will work with the second data matrix: x2 (quadratic effects and many interactions)
set.seed(1212)
cvx2 <- cv.glmnet(x2, y, type.measure = "mse", nfolds = 10, keep = TRUE) ## notice KEEP
plot(cvx2) #Have 64 predictors in total - best Lasso regression model has about 12 parameters
foldid <- cvx2$foldid ## these are the fold memberships
cvx2$foldid
#Can keep the folds constant in our search.
## Now, let's say we are interested in 3 alpha values only:
## 0 (ridge), 0.5 (elastic); 1 (lasso).
# Notice the folded argument!
cv1 = cv.glmnet(x2, y, foldid = foldid, alpha = 1) #lasso
cv.5 = cv.glmnet(x2, y, foldid = foldid, alpha = .5) #elastic net
cv0 = cv.glmnet(x2, y, foldid = foldid, alpha = 0) #ridge
#leaving lambda to be produced by the function
# Let's visualize the CV-ERROR:
par(mfrow = c(2,2))
plot(cv1, main ="alpha = 1");
plot(cv.5, main = "alpha = 0.5");
plot(cv0, main = "alpha = 0")
plot(log(cv1$lambda), cv1$cvm,
pch = 19, col = "red",
xlab = "log(Lambda)", ylab = cv1$name)
points(log(cv.5$lambda), cv.5$cvm, pch = 19, col = "grey")
points(log(cv0$lambda), cv0$cvm, pch = 19, col = "blue")
#legend("topleft",legend=c("alpha= 1","alpha= .5","alpha 0"),pch=19,col=c("red","grey","blue"))
par(mfrow = c(1,1))
## Which model would you choose?
## How if you would like to try alpha.seq = seq(0, 1, .01) - there are 101 different values?
#Can use a for loop for different alpha values - we only used 3 dif ones
#StatQuest has an example
#This is a sequential search.
## In this case, it is good idea to write a program and store your "results" in an organized way. This will help you find the optimal tuning parameters.
#Then find the best alpha value.
## Let's see the results:
attributes(db_net1)
db_net1$results
#shows all the alpha and lambda values tried and can find the optimal model
#3 unique alpha values (alpha = 1 --> lasso) ; ridge was not fit (alpha = 0)
#MAE - mean absolute error
w1 <- which.min(db_net1$results[ ,3]) ## the best pair!
#smallest possible RMSE - best model
db_net1$results[w1, ]  ## notice the value of RMSE_SD
#there can be other models in this same vicinity - they can be somewhat similar
db_net1$bestTune #best model - same as above
## we compute the prediction error on the entire training set
mod_enet1 <- glmnet(x, y, alpha = db_net1$results[w1, 1],
lambda = db_net1$results[w1, 2])
## and the train set MSE is:
mean((y-as.vector(predict(mod_enet1,x)))^2)
## is it better than the ones from LASSO and ridge Reg?
###--
###	Problem: Our grid search is quite small!
###--
#Allows us to have more alpha values
tuneGrid <- expand.grid(.alpha = seq(0, 1, length = 10),
.lambda = seq(.5, 7.5, 1))
dim(tuneGrid)
head(tuneGrid)
db_net2 <- train(x, y, method = "glmnet",
trControl = enet,
tuneGrid = tuneGrid)
## The results
dim(db_net2$results)
head(db_net2$results)
par(mfrow = c(1,2))
plot(db_net2$results[ ,c(1,3)])
plot(db_net2$results[ ,c(2,3)])
par(mfrow = c(1,1))
#lower alpha and lambda - better models
#ridge regression seems best for this dataset
db_net2$bestTune #best model
#View the plot in 3D
alphas <- db_net2$results[,"alpha"]
lambdas <- db_net2$results[,"lambda"]
RMSE <- db_net2$results[,"RMSE"]
plot_ly(x = alphas, y = lambdas, z = RMSE,
type = "scatter3d",
mode = "markers",
color = RMSE)
### Do we need a validation/"test" dataset here?
## Best values:
w2 <- which.min(db_net2$results[ ,3]) ## the best pair!
db_net2$results[w2, ]
##----
## We, also need to look at the variability in RMSE!
summary(db_net2$results[ ,"RMSE"])
summary(db_net2$results[ ,"RMSESD"])
## FOR YOU TO TRY: compute the prediction error on the training
## set for the best fit in db_net2. How does it compare?
### Do we need a validation/"test" dataset here?
##-----------------------------------------------------
##	Tuning Over a Grid of alpha-lambda Values
##-----------------------------------------------------
##---------------------------------------------------------------
# The tuning approach implemented via the caret package above is a general one and may not be applicable in all situations. For instance, it is important in glmnet's implementation of elasticnet to work with a grid of lambda values for a given 'fixed' value of alpha. However, caret calls glmnet by fixing 'both' lambda and alpha in each iteration over the tuneGrid matrix.
# We can handle this issue as follows by relying solely on glmnet functionality alone.
## First, it is a good idea to keep the folds fixed throughout the cross-validations. There are various ways to do it (you should explore this!); here we can extract the folds from a cv.glmnet:
## We will work with the second data matrix: x2 (quadratic effects and many interactions)
set.seed(1212)
cvx2 <- cv.glmnet(x2, y, type.measure = "mse", nfolds = 10, keep = TRUE) ## notice KEEP
plot(cvx2) #Have 64 predictors in total - best Lasso regression model has about 12 parameters
foldid <- cvx2$foldid ## these are the fold memberships
cvx2$foldid
#Can keep the folds constant in our search.
## Now, let's say we are interested in 3 alpha values only:
## 0 (ridge), 0.5 (elastic); 1 (lasso).
# Notice the folded argument!
cv1 = cv.glmnet(x2, y, foldid = foldid, alpha = 1) #lasso
cv.5 = cv.glmnet(x2, y, foldid = foldid, alpha = .5) #elastic net
cv0 = cv.glmnet(x2, y, foldid = foldid, alpha = 0) #ridge
#leaving lambda to be produced by the function
# Let's visualize the CV-ERROR:
par(mfrow = c(2,2))
plot(cv1, main ="alpha = 1");
plot(cv.5, main = "alpha = 0.5");
plot(cv0, main = "alpha = 0")
plot(log(cv1$lambda), cv1$cvm,
pch = 19, col = "red",
xlab = "log(Lambda)", ylab = cv1$name)
points(log(cv.5$lambda), cv.5$cvm, pch = 19, col = "grey")
points(log(cv0$lambda), cv0$cvm, pch = 19, col = "blue")
#legend("topleft",legend=c("alpha= 1","alpha= .5","alpha 0"),pch=19,col=c("red","grey","blue"))
par(mfrow = c(1,1))
## Which model would you choose?
## How if you would like to try alpha.seq = seq(0, 1, .01) - there are 101 different values?
#Can use a for loop for different alpha values - we only used 3 dif ones
#StatQuest has an example
#This is a sequential search.
## In this case, it is good idea to write a program and store your "results" in an organized way. This will help you find the optimal tuning parameters.
#Then find the best alpha value.
#lasso - use when you want to select the best predictors that contribute to the fit
#EN - when you want to extract as much predictive power and allow the function to search for you
